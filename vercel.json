{
  "outputDirectory": "public",
  "framework": null,
  "buildCommand": "",
  "routes": [
    { "src": "^/css/(.*)$",         "dest": "/css/$1" },
    { "src": "^/js/(.*)$",          "dest": "/js/$1" },
    { "src": "^/assets/(.*)$",      "dest": "/assets/$1" },
    { "src": "^/icons/(.*)$",       "dest": "/icons/$1" },
    { "src": "^/manifest\\.json$",  "dest": "/manifest.json" },
    { "src": "^/sw\\.js$",          "dest": "/sw.js" },
    { "src": "^/(.*)$",             "dest": "/coming-soon.html" }
  ]
}
